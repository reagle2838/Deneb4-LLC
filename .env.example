# Copy this file to ".env.local" and fill in values.

# Resend API key — powers the Contact and Start-a-Project forms.
# Without it, form submissions are logged to the server console and still
# return success (so the site works in development). Add a real key and a
# verified sending domain in Resend to send live email.
RESEND_API_KEY=

# Where form submissions are delivered, and the verified "from" address.
CONTACT_TO_EMAIL=hello@deneb4.com
CONTACT_FROM_EMAIL=Deneb4 Website <hello@deneb4.com>

# ── Keystatic CMS authentication ─────────────────────────────────────────────
# Password for the /cms-login page (plain text — stored only on the server).
KEYSTATIC_PASSWORD=

# Base32 TOTP secret for Google Authenticator / Authy.
# Generate one: node -e "const {authenticator}=require('otplib'); console.log(authenticator.generateSecret())"
KEYSTATIC_TOTP_SECRET=

# Secret for signing the cms_auth session cookie (32+ random chars).
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CMS_JWT_SECRET=

# Set to "true" ONLY during initial authenticator setup — visit /cms-setup to scan the QR code.
# Remove this line (or set to false) after scanning.
KEYSTATIC_SETUP=

# ── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID (looks like G-XXXXXXXXXX). When set, GA loads
# on the public site (not the CMS). Must be set BEFORE `npm run build` to take
# effect, since NEXT_PUBLIC_ vars are inlined at build time.
NEXT_PUBLIC_GA_ID=

# ── Agents ───────────────────────────────────────────────────────────────────
# Shared key headless agents send as the x-agent-key header to /api/agents/*.
AGENT_API_KEY=

# OPTIONAL. Enables the Builder's LLM copy-refinement layer (rephrases supplied
# copy only, never invents facts). Left empty, the Builder is fully deterministic.
ANTHROPIC_API_KEY=

# OPTIONAL. Enables the Builder's GitHub push layer: each assembled client
# site gets its own private repo (d4-client-<slug>) under GITHUB_OWNER.
# Token needs repo-create + push scope. Left empty, client repos stay local.
GITHUB_TOKEN=
GITHUB_OWNER=

# OPTIONAL. When "true", approving a change proposal in the Workspace also
# starts the Builder in the background (apply + QA + auto-revert on red).
# Only makes sense where the repo + Node live (Ridhi's machine), not on
# shared hosting. Left empty, approving updates the config and tells you
# the command to run.
BUILDER_AUTORUN=

# OPTIONAL. Model for the Comms agent's LLM triage (only used when
# ANTHROPIC_API_KEY is set). Defaults to claude-haiku-4-5-20251001.
COMMS_LLM_MODEL=
