# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db
desktop.ini

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files
.env
.env*.local

# typescript
*.tsbuildinfo
next-env.d.ts

# vercel
.vercel

# uploaded client files (kept on the server, not in git)
/public/uploads/*
!/public/uploads/.gitkeep

# Claude Code local settings + personal hooks (not shared)
.claude/settings.local.json
.claude/hooks/

# Agent heartbeat run log + dedup state (ephemeral, regenerated at runtime)
/content/admin/agent-runs.yaml
/content/admin/agent-state.yaml
# Handoff packages contain live credentials; never commit them.
/content/admin/handoffs/
# Staged content seeds are transient review state; applied or discarded, never committed.
/content/admin/seeds/
# Staged intake proposals are transient review state.
/content/admin/intake/
# Wave customer/product IDs — account-specific operational state, regenerated on demand.
/content/admin/wave/

# Builder: per-client assembled build artifacts (each is its own git repo)
/builds/

# Local mirror of the d4 template ecosystem (cloned/pulled by the Builder)
/vendor/d4/
