{
  "id": "starter",
  "version": "1.0.0",
  "kind": "static",
  "modules": {
    "hero": {
      "required": true,
      "section": "hero",
      "route": null,
      "slots": { "headline": "required", "subhead": "optional" }
    },
    "services": {
      "required": false,
      "section": "services",
      "route": "/services",
      "navLabel": "Services",
      "slots": { "services_intro": "required", "service_items": "optional" }
    },
    "contact": {
      "required": false,
      "section": "contact",
      "route": "/contact",
      "navLabel": "Contact",
      "slots": { "contact_email": "required", "contact_blurb": "optional" }
    }
  },
  "presets": {
    "slate-teal": {
      "--accent": "#006b8f",
      "--accent-light": "#1f93ba",
      "--bg-base": "#f2f5f9",
      "--bg-surface": "#ffffff",
      "--text-heading": "#080f1a",
      "--text-muted": "#4e606f"
    },
    "warm-sand": {
      "--accent": "#b4632a",
      "--accent-light": "#d98a4e",
      "--bg-base": "#faf6f0",
      "--bg-surface": "#ffffff",
      "--text-heading": "#231a12",
      "--text-muted": "#6b5a48"
    }
  },
  "layouts": ["standard", "centered"],
  "baseRoutes": ["/"],
  "assets": ["/theme.css", "/base.css"]
}
